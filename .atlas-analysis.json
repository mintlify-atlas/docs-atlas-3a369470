  "keyFeatures": [
    "Domain-based HTTP reverse proxy using Host header routing",
    "SQLite-backed persistent configuration storage",
    "REST API for dynamic domain mapping management",
    "Bearer token API key authentication",
    "Domain restriction middleware for API endpoint access",
    "Support for HTTP and HTTPS backend protocols",
    "Bulk domain creation endpoint for batch operations",
    "Docker and Docker Compose support",
    "Debug logging mode",
    "Health check endpoint"
  ],
  "publicApiSurface": [
    "GET /api/config — List all domain mappings",
    "GET /api/config/:domain — Get a specific domain mapping",
    "POST /api/config — Create a domain mapping",
    "PUT /api/config/:domain — Update a domain mapping",
    "DELETE /api/config/:domain — Delete a domain mapping",
    "POST /api/config/bulk — Bulk create domain mappings",
    "GET /health — Health check endpoint",
    "GET /whoami — Diagnostic information endpoint"
  ]
